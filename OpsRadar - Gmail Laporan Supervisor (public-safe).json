    {
      "parameters": {
        "jsCode": "const email = $input.first().json;\nconst body = email.text || email.snippet || '';\n\nfunction getSection(startMarker, endMarker) {\n  const startIdx = body.indexOf(startMarker);\n  if (startIdx === -1) return '';\n  const afterStart = body.slice(startIdx + startMarker.length);\n  if (!endMarker) return afterStart;\n  const endIdx = afterStart.indexOf(endMarker);\n  return endIdx === -1 ? afterStart : afterStart.slice(0, endIdx);\n}\n\nfunction extractFrom(text, pattern, fallback = '') {\n  const match = text.match(pattern);\n  return match ? match[1].trim() : fallback;\n}\n\nfunction parsePipeRecords(sectionText) {\n  const teks = sectionText.trim();\n  if (!teks || /^NIHIL/i.test(teks)) return [];\n\n  const posisiAwal = [];\n  const pola = /(?:^|\\n)\\s*\\d+\\s*\\|/g;\n  let cocok;\n  while ((cocok = pola.exec(teks)) !== null) {\n    const mulaiDariAngka = cocok[0].startsWith('\\n') ? cocok.index + 1 : cocok.index;\n    posisiAwal.push(mulaiDariAngka);\n  }\n\n  const hasil = [];\n  for (let i = 0; i < posisiAwal.length; i++) {\n    const mulai = posisiAwal[i];\n    const akhir = i + 1 < posisiAwal.length ? posisiAwal[i + 1] : teks.length;\n    let satuData = teks.slice(mulai, akhir).trim();\n    satuData = satuData.replace(/\\s*\\n\\s*/g, ' ');\n    hasil.push(satuData);\n  }\n  return hasil;\n}\n\nconst bagianAtas = getSection('', '--- KONDISI MESIN ---');\nconst tanggal = extractFrom(bagianAtas, /Tanggal\\s*:\\s*([\\d-]+)/i);\n\nconst bagianDowntime = getSection('--- DOWNTIME ---', '--- STOK BAHAN BAKAR ---');\nconst daftarData = parsePipeRecords(bagianDowntime);\n\n// Perbaikan: baris yang datanya kurang dari 5 bagian (nomor, waktu,\n// penyebab, durasi, bagian mesin) akan DILEWATI, tidak masuk ke Sheets\nconst hasilItems = [];\nfor (const satuBaris of daftarData) {\n  const kolom = satuBaris.split('|').map(k => k.trim());\n  if (kolom.length < 5 || !kolom[1] || !kolom[2] || !kolom[4]) {\n    continue; // data tidak lengkap, lewati baris ini\n  }\n  hasilItems.push({\n    json: {\n      tanggal: tanggal,\n      waktu_kejadian: kolom[1],\n      penyebab: kolom[2],\n      durasi: parseFloat(kolom[3].replace(',', '.')) || 0,\n      bagian_mesin: kolom[4],\n      status: 'SELESAI'\n    }\n  });\n}\n\nreturn hasilItems;"
      },
