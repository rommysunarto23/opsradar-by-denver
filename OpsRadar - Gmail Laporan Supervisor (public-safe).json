      "parameters": {
        "jsCode": "const email = $input.first().json;\nconst body = email.text || email.snippet || '';\n\nfunction extractFrom(text, pattern, fallback = '') {\n  const match = text.match(pattern);\n  return match ? match[1].trim() : fallback;\n}\n\n// Perbaikan: sekarang bisa baca SEMUA gaya penulisan angka:\n// \"9,5\" (koma sebagai desimal) → 9.5\n// \"1.234,5\" (titik ribuan + koma desimal, gaya Indonesia) → 1234.5\n// \"1,234.5\" (koma ribuan + titik desimal, gaya Inggris) → 1234.5\n// \"125\" (angka biasa tanpa koma/titik) → 125\nfunction bersihkanAngka(teksAngka) {\n  let teks = teksAngka.trim();\n  const posisiKoma = teks.lastIndexOf(',');\n  const posisiTitik = teks.lastIndexOf('.');\n\n  if (posisiKoma === -1 && posisiTitik === -1) {\n    return teks; // tidak ada koma/titik, angka biasa\n  }\n\n  if (posisiKoma > posisiTitik) {\n    // koma muncul PALING TERAKHIR → koma ini yang jadi tanda desimal\n    // titik-titik sebelumnya (kalau ada) itu cuma pemisah ribuan, buang\n    teks = teks.replace(/\\./g, '');\n    teks = teks.replace(',', '.');\n  } else {\n    // titik muncul PALING TERAKHIR → titik ini yang jadi tanda desimal\n    // koma-koma sebelumnya (kalau ada) itu cuma pemisah ribuan, buang\n    teks = teks.replace(/,/g, '');\n  }\n  return teks;\n}\n\nfunction extractNumberFrom(text, pattern, fallback = 0) {\n  const value = extractFrom(text, pattern, '');\n  const bersih = bersihkanAngka(value);\n  const num = parseFloat(bersih);\n  return isNaN(num) ? fallback : num;\n}\n\nfunction getSection(startMarker, endMarker) {\n  const startIdx = body.indexOf(startMarker);\n  if (startIdx === -1) return '';\n  const afterStart = body.slice(startIdx + startMarker.length);\n  if (!endMarker) return afterStart;\n  const endIdx = afterStart.indexOf(endMarker);\n  return endIdx === -1 ? afterStart : afterStart.slice(0, endIdx);\n}\n\nfunction extractMaterial(text, nama) {\n  const pattern = new RegExp(nama.replace(/-/g, '\\\\-') + '\\\\s*:\\\\s*([\\\\d.,]+)', 'i');\n  return extractNumberFrom(text, pattern);\n}\n\nfunction hitungBarisData(sectionText) {\n  const teks = sectionText.trim();\n  if (!teks || /^NIHIL/i.test(teks)) return 0;\n  const cocok = teks.match(/(?:^|\\n)\\s*\\d+\\s*\\|/g);\n  return cocok ? cocok.length : 0;\n}\n\nconst bagianAtas = getSection('', '--- KONDISI MESIN ---');\nconst bagianMesin = getSection('--- KONDISI MESIN ---', '--- JAM OPERASIONAL ---');\nconst bagianJam = getSection('--- JAM OPERASIONAL ---', '--- MATERIAL MASUK ---');\nconst bagianMasuk = getSection('--- MATERIAL MASUK ---', '--- PRODUKSI HARI INI ---');\nconst bagianProduksi = getSection('--- PRODUKSI HARI INI ---', '--- MATERIAL KELUAR');\nconst bagianKeluar = getSection('--- MATERIAL KELUAR', '--- DOWNTIME ---');\nconst bagianDowntime = getSection('--- DOWNTIME ---', '--- STOK BAHAN BAKAR ---');\nconst bagianSolar = getSection('--- STOK BAHAN BAKAR ---', '--- INVENTARIS');\nconst bagianInventaris = getSection('--- INVENTARIS DIBUTUHKAN ---', '--- ABSENSI');\nconst bagianAbsensi = getSection('--- ABSENSI KARYAWAN ---', '--- INFORMASI TAMBAHAN');\nconst bagianInfoTambahan = getSection('--- INFORMASI TAMBAHAN ---', '--- TAMU ---');\nconst bagianTamu = getSection('--- TAMU ---', '');\n\nconst tanggal = extractFrom(bagianAtas, /Tanggal\\s*:\\s*([\\d-]+)/i);\nconst supervisor = extractFrom(bagianAtas, /Supervisor\\s*:\\s*(.+)/i);\nconst dataValid = (tanggal !== '' && supervisor !== '');\n\nreturn [\n  {\n    json: {\n      data_valid: dataValid,\n      tanggal: tanggal,\n      supervisor: supervisor,\n      kondisi_awal: extractFrom(bagianMesin, /Kondisi awal\\s*:\\s*(.+)/i),\n      status_akhir: extractFrom(bagianMesin, /Status akhir\\s*:\\s*(.+)/i),\n      jam_mulai: extractFrom(bagianJam, /Mulai\\s*:\\s*([\\d:]+)/i),\n      jam_selesai: extractFrom(bagianJam, /Selesai\\s*:\\s*([\\d:]+)/i),\n      total_jam: extractNumberFrom(bagianJam, /Total\\s*:\\s*([\\d.,]+)/i),\n      material_masuk: extractNumberFrom(bagianMasuk, /Total material masuk\\s*:\\s*([\\d.,]+)/i),\n      produksi_batu58: extractMaterial(bagianProduksi, 'Batu 5-8'),\n      produksi_suplit12: extractMaterial(bagianProduksi, 'Suplit 1-2'),\n      produksi_suplit23: extractMaterial(bagianProduksi, 'Suplit 2-3'),\n      produksi_batumedium: extractMaterial(bagianProduksi, 'Batu Medium'),\n      produksi_abubatu: extractMaterial(bagianProduksi, 'Abu Batu'),\n      produksi_limbah: extractMaterial(bagianProduksi, 'Limbah'),\n      total_produksi: extractNumberFrom(bagianProduksi, /TOTAL PRODUKSI\\s*:\\s*([\\d.,]+)/i),\n      keluar_batu58: extractMaterial(bagianKeluar, 'Batu 5-8'),\n      keluar_suplit12: extractMaterial(bagianKeluar, 'Suplit 1-2'),\n      keluar_suplit23: extractMaterial(bagianKeluar, 'Suplit 2-3'),\n      keluar_batumedium: extractMaterial(bagianKeluar, 'Batu Medium'),\n      keluar_abubatu: extractMaterial(bagianKeluar, 'Abu Batu'),\n      keluar_limbah: extractMaterial(bagianKeluar, 'Limbah'),\n      total_keluar: extractNumberFrom(bagianKeluar, /TOTAL KELUAR\\s*:\\s*([\\d.,]+)/i),\n      stok_solar: extractNumberFrom(bagianSolar, /Solar\\s*:\\s*([\\d.,]+)/i),\n      jumlah_macet: hitungBarisData(bagianDowntime),\n      jumlah_tamu: hitungBarisData(bagianTamu),\n      inventaris: bagianInventaris.trim() || 'NIHIL',\n      absensi: bagianAbsensi.trim() || 'NIHIL',\n      info_tambahan: bagianInfoTambahan.trim() || 'NIHIL',\n    }\n  }\n];"
      },
